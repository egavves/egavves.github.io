{
  "$schema": "calli-pipeline-v1",
  "name": "Calli Production Pipeline",
  "version": "2.0.0",
  "description": "Sequential multi-agent ideation pipeline with write-locally-first pattern, template-grounded generation, and critic review",

  "chain_of_thought": "agents/CHAIN_OF_THOUGHT.md",
  "templates": {
    "production_note": "data/cut/ideation_dataset/PRODUCTION_NOTE_TEMPLATE.md",
    "storyboard": "data/cut/ideation_dataset/templates/STORYBOARD_TEMPLATE.md",
    "script": "data/cut/ideation_dataset/templates/SCRIPT_TEMPLATE.md",
    "casting": "data/cut/ideation_dataset/templates/CASTING_TEMPLATE.md",
    "production": "data/cut/ideation_dataset/templates/PRODUCTION_TEMPLATE.md",
    "titles": "data/cut/ideation_dataset/templates/TITLES_TEMPLATE.md",
    "thumbnails": "data/cut/ideation_dataset/templates/THUMBNAILS_TEMPLATE.md",
    "distribution": "data/cut/ideation_dataset/templates/DISTRIBUTION_TEMPLATE.md",
    "validation": "data/cut/ideation_dataset/templates/VALIDATION_TEMPLATE.md"
  },

  "execution": {
    "mode": "sequential",
    "max_revisions_per_stage": 2,
    "critic_review": "after_each_stage",
    "user_checkpoints": ["after_concept", "after_validation"],
    "timeout_per_stage_ms": 120000,
    "write_locally_first": true,
    "verify_completeness": true,
    "truncation_recovery": true
  },

  "token_budgets": {
    "concept": 16000,
    "script": 12000,
    "storyboard": 8192,
    "casting": 6000,
    "production": 6000,
    "titles": 4096,
    "distribution": 4096,
    "thumbnails": 800,
    "validation": 3000,
    "audience_panel": 2000
  },

  "stages": [
    {
      "id": "concept",
      "agent": "orchestrator",
      "delegates_to": "writer",
      "critic_review": true,
      "user_checkpoint": true,
      "template": "production_note",
      "inputs": ["config", "ml_insights", "ref_doc", "user_brief"],
      "outputs": ["concept_text", "formula", "title"],
      "output_file": "concept.md",
      "also_writes": ["production_note.md"],
      "min_sections": 20,
      "min_words": 3000,
      "description": "Generate FULL production note (Parts A + B, all 20 sections). Writer drafts from template, Orchestrator shapes, Critic reviews. Must include ≥12 hypothesis hyperlinks."
    },
    {
      "id": "storyboard",
      "agent": "creative_director",
      "critic_review": true,
      "user_checkpoint": false,
      "template": "storyboard",
      "inputs": ["concept_text", "config"],
      "outputs": ["storyboard_scenes"],
      "output_file": "storyboard.md",
      "can_request": ["data_analyst"],
      "min_scenes": 4,
      "min_words": 800,
      "description": "Visual storyboard with 4-6 scenes. Must read concept.md first. Character names and timestamps must match concept. Each scene needs Visual Description, Action, Mood, and Director's Note."
    },
    {
      "id": "script",
      "agent": "writer",
      "critic_review": true,
      "user_checkpoint": false,
      "template": "script",
      "inputs": ["concept_text", "storyboard_scenes", "config"],
      "outputs": ["script_text"],
      "output_file": "script.md",
      "can_request": ["data_analyst"],
      "min_words": 2000,
      "description": "FULL video script. Must read concept.md AND storyboard.md first. Every round of the loop written out — NO summarizing. Character names match. WTF moment appears. Cold open hook in first 15 seconds."
    },
    {
      "id": "casting",
      "agent": "creative_director",
      "critic_review": false,
      "user_checkpoint": false,
      "template": "casting",
      "inputs": ["concept_text", "script_text", "config"],
      "outputs": ["casting_notes"],
      "output_file": "casting.md",
      "min_words": 600,
      "description": "Casting brief ONLY — no script content, no production notes. Must include: Demographics, Archetype table, Values, Red Flags, Gender Mix, Regional Voice, North Star."
    },
    {
      "id": "production",
      "agent": "orchestrator",
      "critic_review": false,
      "user_checkpoint": false,
      "template": "production",
      "inputs": ["concept_text", "storyboard_scenes", "script_text", "casting_notes", "config"],
      "outputs": ["production_plan"],
      "output_file": "production.md",
      "min_words": 800,
      "description": "Full production plan with all 6 sections: Location, Props/Wardrobe, Crew, Camera, Pacing, Risks. All tables must be complete — no empty cells."
    },
    {
      "id": "titles",
      "agent": "writer",
      "critic_review": true,
      "user_checkpoint": false,
      "template": "titles",
      "inputs": ["concept_text", "ml_insights", "config"],
      "outputs": ["title_options"],
      "output_file": "titles.md",
      "can_request": ["data_analyst"],
      "min_titles": 8,
      "min_words": 800,
      "description": "8 title options across categories with 3-4 sentence 'Why it works' for each. Must include ML feature references. Ends with RECOMMENDATION + A/B Test."
    },
    {
      "id": "thumbnails",
      "agent": "creative_director",
      "critic_review": true,
      "user_checkpoint": false,
      "template": "thumbnails",
      "inputs": ["concept_text", "title_options", "ml_insights", "config"],
      "outputs": ["thumbnail_concepts"],
      "output_file": "thumbnails.md",
      "description": "3 distinct thumbnail concepts as JSON. Each with prompt (50-80 words), text_overlay, hook."
    },
    {
      "id": "distribution",
      "agent": "orchestrator",
      "critic_review": false,
      "user_checkpoint": false,
      "template": "distribution",
      "inputs": ["concept_text", "title_options", "thumbnail_concepts", "config"],
      "outputs": ["distribution_plan"],
      "output_file": "distribution.md",
      "min_words": 800,
      "description": "Full distribution plan: Cadence, Platform Cuts (YouTube Shorts + TikTok + Reels), Community Posts, Collab. Each Short references a specific episode moment."
    },
    {
      "id": "audience_panel",
      "agent": "audience",
      "critic_review": false,
      "user_checkpoint": true,
      "inputs": ["concept_text", "title_options", "thumbnail_concepts", "storyboard_scenes"],
      "outputs": ["audience_votes", "audience_feedback"],
      "description": "5 audience personas independently react and vote. Results feed validation."
    },
    {
      "id": "validation",
      "agent": "critic",
      "critic_review": false,
      "user_checkpoint": false,
      "template": "validation",
      "inputs": ["concept_text", "storyboard_scenes", "script_text", "audience_votes", "audience_feedback", "ml_insights"],
      "outputs": ["validation_report"],
      "output_file": "validation.md",
      "description": "Final validation synthesizing Critic's notes, audience panel, and ML evidence. Includes hypothesis coverage audit."
    }
  ],

  "feedback_loops": {
    "critic_rejection": {
      "trigger": "critic rates stage < 6/10",
      "action": "send_back_to_stage_agent with critic notes",
      "max_iterations": 2
    },
    "truncation_recovery": {
      "trigger": "output ends mid-sentence OR missing required sections",
      "action": "re-invoke agent with continuation prompt: 'Previous output truncated at: {last_line}. Continue from that point and complete ALL remaining sections.'",
      "max_retries": 2
    },
    "content_contamination": {
      "trigger": "output file contains content from a different stage (e.g., script content in casting file)",
      "action": "re-invoke agent with strict instruction: 'Generate ONLY {stage_name} content. Do NOT include any {contaminating_stage} content.'"
    },
    "user_intervention": {
      "trigger": "user sends message via Calliope during pipeline",
      "action": "pause_pipeline, inject_user_note, resume_from_current_or_specified_stage"
    },
    "cross_agent_request": {
      "trigger": "agent includes [REQUEST:agent_id] tag in output",
      "action": "route request to target agent, inject response, continue generation"
    }
  },

  "completeness_verification": {
    "concept": {
      "required_sections": ["Concept", "Thumbnail & Title Strategy", "Cast", "The Loop", "Psychological Drivers", "Story Structure", "Emotional Design", "Production Design", "Questions & Prompts", "Packaging", "Performance Notes", "Strong Characters", "Early Retention", "Reason to Watch to the End", "Loop Structure Test", "Format Type Read", "YouTube Format Fitness", "Scorecard", "Structural Fragility", "Top Strengths", "Development Diagnosis"],
      "required_hypothesis_count": 12
    },
    "storyboard": {
      "required_sections": ["SCENE 1", "SCENE 2", "SCENE 3", "SCENE 4"],
      "required_per_scene": ["Visual Description", "On-Screen Action", "Mood"],
      "required_hypothesis_count": 2
    },
    "script": {
      "required_sections": ["COLD OPEN", "SCENE 1", "SCENE 2", "SCENE 3"],
      "verify_all_rounds": true,
      "required_hypothesis_count": 2
    },
    "casting": {
      "required_sections": ["Demographics & Energy", "Character Archetypes", "What We Value", "Red Flags", "Gender Mix", "Casting North Star"],
      "no_contamination_from": ["script", "production"],
      "required_hypothesis_count": 2
    },
    "titles": {
      "required_count": 8,
      "required_sections": ["RECOMMENDATION"],
      "required_hypothesis_count": 2
    }
  }
}
